# Optional: override WebRTC signaling server URL.
# Default: wss://signal-nardy.onrender.com (hosted on Render).
# For local dev with a signal server on this machine:
#   VITE_SIGNALING_URL=ws://localhost:8080
# See docs/SIGNAL_SERVER.md for details.
# VITE_SIGNALING_URL=ws://localhost:8080

# Supabase (required for ranked auth: sign-in and identify by JWT).
# Same project as the signal server; use the anon (public) key for the frontend.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
